{
  "name": "shad-expo-studio",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=20.10.0"
  },
  "author": {
    "name": "Shad Expo Studio"
  },
  "pnpm": {
    "overrides": {
      "react-server-dom-webpack": "19.1.2",
      "react-server-dom-parcel": "19.1.2",
      "react-server-dom-turbopack": "19.1.2",
      "@isaacs/brace-expansion@5": "5.0.1",
      "@tootallnate/once@2": "2.0.1",
      "@xmldom/xmldom@0.8": "0.8.13",
      "ajv@6": "6.14.0",
      "ajv@8": "8.20.0",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "fast-uri@3": "3.1.3",
      "flatted": "3.4.2",
      "form-data@4": "4.0.6",
      "js-yaml@3": "3.15.0",
      "js-yaml@4": "4.2.0",
      "lodash": "4.18.0",
      "minimatch@3": "3.1.4",
      "minimatch@8": "8.0.6",
      "minimatch@9": "9.0.7",
      "minimatch@10": "10.2.5",
      "node-forge": "1.4.0",
      "postcss@8": "8.5.16",
      "shell-quote": "1.8.4",
      "svgo@3": "3.3.3",
      "tar@7": "7.5.16",
      "undici@6": "6.27.0",
      "ws@6": "6.2.4",
      "ws@7": "7.5.11",
      "ws@8": "8.21.0",
      "yaml@2": "2.8.3"
    }
  },
  "scripts": {
    "preinstall": "node tooling/check-env.js",
    "turbo": "turbo",
    "postinstall": "manypkg fix",
    "build": "turbo build --cache-dir=.turbo",
    "clean": "git clean -xdf node_modules dist .next",
    "clean:workspaces": "turbo clean",
    "format": "turbo format --cache-dir=.turbo --continue -- --cache --cache-location=\"node_modules/.cache/.prettiercache\" --ignore-path=\"../../.gitignore\"",
    "format:fix": "turbo format --cache-dir=.turbo --continue -- --write --cache --cache-location=\"node_modules/.cache/.prettiercache\" --ignore-path=\"../../.gitignore\"",
    "lint": "turbo lint --cache-dir=.turbo --affected --continue -- --cache --cache-location \"node_modules/.cache/.eslintcache\" && manypkg check",
    "lint:fix": "turbo lint --cache-dir=.turbo --affected --continue -- --fix --cache --cache-location \"node_modules/.cache/.eslintcache\" && manypkg fix",
    "lint:all": "turbo lint --cache-dir=.turbo --continue -- --cache --cache-location \"node_modules/.cache/.eslintcache\" && manypkg check",
    "typecheck": "turbo typecheck --affected --cache-dir=.turbo",
    "typecheck:all": "turbo typecheck --cache-dir=.turbo",
    "test": "turbo test --cache-dir=.turbo",
    "ios": "pnpm --filter expo-app ios",
    "android": "pnpm --filter expo-app android",
    "web": "pnpm --filter expo-app web",
    "preview": "pnpm --filter expo-app stories:generate && pnpm --filter expo-app storybook",
    "chromatic": "pnpm --filter expo-app chromatic",
    "chromatic:main": "pnpm --filter expo-app chromatic:main",
    "registry:build": "pnpm dlx shadcn@4.12.0 build",
    "update": "pnpm update -r",
    "syncpack:list": "pnpm dlx syncpack list-mismatches",
    "syncpack:fix": "pnpm dlx syncpack fix-mismatches"
  },
  "prettier": "@studio/prettier-config",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@manypkg/cli": "^0.25.1",
    "prettier": "^3.6.2",
    "turbo": "2.9.14",
    "typescript": "^5.9.3"
  }
}
